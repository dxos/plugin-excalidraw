{
  "name": "dxos-plugin-excalidraw",
  "private": true,
  "version": "0.1.26",
  "description": "Excalidraw sketch plugin for DXOS Composer — standalone community distribution of the @dxos/plugin-excalidraw package.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "imports": {
    "#capabilities": {
      "source": "./src/capabilities/index.ts",
      "types": "./dist/types/src/capabilities/index.d.ts",
      "default": "./dist/lib/neutral/capabilities/index.mjs"
    },
    "#components": {
      "source": "./src/components/index.ts",
      "types": "./dist/types/src/components/index.d.ts",
      "default": "./dist/lib/neutral/components/index.mjs"
    },
    "#containers": {
      "source": "./src/containers/index.ts",
      "types": "./dist/types/src/containers/index.d.ts",
      "default": "./dist/lib/neutral/containers/index.mjs"
    },
    "#hooks": {
      "source": "./src/hooks/index.ts",
      "types": "./dist/types/src/hooks/index.d.ts",
      "default": "./dist/lib/neutral/hooks/index.mjs"
    },
    "#meta": {
      "source": "./src/meta.ts",
      "types": "./dist/types/src/meta.d.ts",
      "default": "./dist/lib/neutral/meta.mjs"
    },
    "#operations": {
      "source": "./src/operations/index.ts",
      "types": "./dist/types/src/operations/index.d.ts",
      "default": "./dist/lib/neutral/operations/index.mjs"
    },
    "#plugin": {
      "source": "./src/ExcalidrawPlugin.tsx",
      "types": "./dist/types/src/ExcalidrawPlugin.d.ts",
      "default": "./dist/lib/neutral/ExcalidrawPlugin.mjs"
    },
    "#translations": {
      "source": "./src/translations.ts",
      "types": "./dist/types/src/translations.d.ts",
      "default": "./dist/lib/neutral/translations.mjs"
    },
    "#types": {
      "source": "./src/types/index.ts",
      "types": "./dist/types/src/types/index.d.ts",
      "default": "./dist/lib/neutral/types/index.mjs"
    }
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/types/src/index.d.ts",
      "default": "./dist/lib/neutral/index.mjs"
    },
    "./plugin": {
      "source": "./src/plugin.ts",
      "types": "./dist/types/src/plugin.d.ts",
      "default": "./dist/lib/neutral/plugin.mjs"
    }
  },
  "//": "@dxos/* deps track the `main` dist-tag on npm so the plugin runs against the same Composer host code that edge-main serves. Bump SHAs in lockstep when landing a host-side change.",
  "dependencies": {
    "@automerge/automerge": "3.2.3",
    "@dxos/app-framework": "0.8.4-main.51f1e5ca51",
    "@dxos/app-toolkit": "0.8.4-main.51f1e5ca51",
    "@dxos/async": "0.8.4-main.51f1e5ca51",
    "@dxos/client": "0.8.4-main.51f1e5ca51",
    "@dxos/client-protocol": "0.8.4-main.51f1e5ca51",
    "@dxos/compute": "0.8.4-main.51f1e5ca51",
    "@dxos/echo": "0.8.4-main.51f1e5ca51",
    "@dxos/echo-db": "0.8.4-main.51f1e5ca51",
    "@dxos/echo-react": "0.8.4-main.51f1e5ca51",
    "@dxos/effect": "0.8.4-main.51f1e5ca51",
    "@dxos/invariant": "0.8.4-main.51f1e5ca51",
    "@dxos/log": "0.8.4-main.51f1e5ca51",
    "@dxos/operation": "0.8.4-main.51f1e5ca51",
    "@dxos/plugin-space": "0.8.4-main.51f1e5ca51",
    "@dxos/react-client": "0.8.4-main.51f1e5ca51",
    "@dxos/react-ui": "0.8.4-main.51f1e5ca51",
    "@dxos/react-ui-form": "0.8.4-main.51f1e5ca51",
    "@dxos/react-ui-stack": "0.8.4-main.51f1e5ca51",
    "@dxos/ui-theme": "0.8.4-main.51f1e5ca51",
    "@dxos/util": "0.8.4-main.51f1e5ca51",
    "@effect-atom/atom": "^0.5.0",
    "@effect-atom/atom-react": "^0.5.0",
    "@excalidraw/excalidraw": "^0.18.0",
    "effect": "^3.19.0",
    "lodash.defaultsdeep": "^4.6.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-resize-detector": "^12.3.0"
  },
  "devDependencies": {
    "@types/lodash.defaultsdeep": "^4.6.9",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "typescript": "~5.9.0",
    "vite": "^8.0.0",
    "vite-plugin-wasm": "^3.6.0"
  }
}
